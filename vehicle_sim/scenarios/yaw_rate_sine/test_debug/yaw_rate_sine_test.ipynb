      "시나리오 생성 완료: steps=5500, t_end=5.499s, target=30.0 kph, amp=0.050 rad/s, freq=0.25 Hz\n",
      "steps      : 5500\n",
      "dt         : 1.0 ms\n",
      "t_end      : 5.499 s\n",
      "target_mps : 8.333 m/s  (30.0 kph)\n",
      "amp        : 0.0500 rad/s\n",
      "yaw_rate_ref shape: (5500,)\n"
